# Copy to .env, then `docker compose up -d --build`.

# UID Airflow runs as inside the container. On Linux, set to your host UID
# (`echo $(id -u)`) so files written into ./logs and ./data are owned by you.
AIRFLOW_UID=50000

# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required to encrypt connection passwords stored in the metadata DB.
AIRFLOW_FERNET_KEY=

# Initial admin user (created on first `airflow-init` run).
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
